{
  "name": "sheetforge-server",
  "version": "2.0.0",
  "description": "SheetForge — Scanned image to DXF + G-Code pipeline via sharp CV pre-processing and Claude Vision AI",
  "license": "MIT",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev":   "nodemon server.js",
    "python": "python process.py",
    "all": "concurrently \"npm run python\" \"npm run dev\""
  },
  "files": [
    "server.js",
    "process.py",
    "requirements.txt",
    "runtime.txt",
    "uploads/",
    ".env.example"
  ],

  "dependencies": {
    "express":            "^4.19.2",
    "pdfkit":             "^0.15.2",
    "mongoose":           "^8.4.0",
    "cors":               "^2.8.5",
    "helmet":             "^7.1.0",
    "morgan":             "^1.10.0",
    "multer":             "^2.1.1",
    "cloudinary":         "^2.3.0",
    "jsonwebtoken":       "^9.0.2",
    "bcryptjs":           "^2.4.3",
    "dotenv":             "^16.4.5",
    "@anthropic-ai/sdk":  "^0.24.3",
    "sharp":              "^0.34.5",
    "@tarikjabiri/dxf":   "^2.8.9",
    "pdf2pic":            "^3.2.0",
    "pdf-parse":          "^2.4.5",
    "jimp":               "^1.6.1",
    "canvas":             "^3.2.3",
    "image-js":           "^1.6.1",
    "potrace":            "^2.1.8",
    "opentype.js":        "^2.0.0",
    "svg-parser":         "^2.0.4",
    "dxf-parser":         "^1.1.2",
    "axios":              "^1.7.2",
    "form-data":          "^4.0.0",
    "archiver":           "^7.0.1",
    "tmp":                "^0.2.5",
    "winston":            "^3.19.0",
    "express-rate-limit": "^8.5.2",
    "node-fetch":         "^3.3.2",
    "mongodb":            "^6.7.0",
    "compression":        "^1.8.1",
    "socket.io":          "^4.7.5",
    "uuid":               "^10.0.0" 
  },

  "devDependencies": {
    "nodemon": "^3.1.3",
    "concurrently": "^8.2.2"
  },

  "engines": {
    "node": ">=18.0.0"
  }
}
